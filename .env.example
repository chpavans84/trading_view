# ─────────────────────────────────────────────────────────────────────────────
# Trading Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (Local AI — optional, free) ───────────────────────────────────────
# Install: brew install ollama && ollama pull llama3.1:8b
# When running, morning briefings and EOD summaries use the local model (free).
# Falls back to Anthropic automatically if Ollama is not running.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Alpaca Paper Trading ──────────────────────────────────────────────────────
# Get from: https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
# Paper URL for testing, live URL for real money:
#   Paper: https://paper-api.alpaca.markets
#   Live:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram to get the token.
# Get your chat ID by messaging @userinfobot on Telegram.
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# DB_PASSWORD is used by docker-compose to create the postgres container.
# DATABASE_URL is what the app connects to.
#   Running locally (no Docker): keep @localhost
#   Running in Docker:           change @localhost → @db  (the service name)
DB_PASSWORD=change-this-db-password
DATABASE_URL=postgresql://postgres:change-this-db-password@localhost:5432/tradingbot

# ── Web Dashboard ─────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_PASSWORD=change-me-before-sharing
# Must be a long random string — generate with: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-secret

# ── Moomoo OpenD ──────────────────────────────────────────────────────────────
# OpenD must be running on the same machine or local network.
# Default when OpenD runs on the same machine:
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
# Trading environment: SIMULATE (paper) or REAL (live). Start with SIMULATE.
MOOMOO_TRADE_ENV=SIMULATE
# Moomoo trading PIN (6-digit password set in the Moomoo app):
MOOMOO_TRADE_PASSWORD=123456

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# Used for email alerts and daily briefing delivery (optional).
RESEND_API=re_...
RESEND_FROM=alerts@yourdomain.com
