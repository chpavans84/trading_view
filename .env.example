# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram chat ID — message @userinfobot to get it
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Claude AI (Anthropic) ────────────────────────────────────────────────────
# Get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Alpaca Trading ───────────────────────────────────────────────────────────
# Get from alpaca.markets → API Keys (use Paper Trading keys to start safely)
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Paper trading (safe, $100K virtual) — change to https://api.alpaca.markets for live
ALPACA_BASE_URL=https://paper-api.alpaca.markets
