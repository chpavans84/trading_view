# ─────────────────────────────────────────────────────────────────────────────
# Trading Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (Local AI — optional, free) ───────────────────────────────────────
# Install: brew install ollama && ollama pull llama3.1:8b
# When running, morning briefings and EOD summaries use the local model (free).
# Falls back to Anthropic automatically if Ollama is not running.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Alpaca Paper Trading ──────────────────────────────────────────────────────
# Get from: https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
# Paper URL for testing, live URL for real money:
#   Paper: https://paper-api.alpaca.markets
#   Live:  https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# DB_PASSWORD is used by docker-compose to create the postgres container.
# DATABASE_URL is what the app connects to.
#   Running locally (no Docker): keep @localhost
#   Running in Docker:           change @localhost → @db  (the service name)
DB_PASSWORD=change-this-db-password
DATABASE_URL=postgresql://postgres:change-this-db-password@localhost:5432/tradingbot

# ── Web Dashboard ─────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_PASSWORD=change-me-before-sharing
# Must be a long random string — generate with: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-secret

# ── Moomoo OpenD ──────────────────────────────────────────────────────────────
# OpenD must be running on the same machine or local network.
# Default when OpenD runs on the same machine:
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111
# Trading environment: SIMULATE (paper) or REAL (live). Start with SIMULATE.
MOOMOO_TRADE_ENV=SIMULATE
# Moomoo trading PIN (6-digit password set in the Moomoo app):
MOOMOO_TRADE_PASSWORD=123456

# ── Benzinga Market Data ─────────────────────────────────────────────────────
# Get from: https://www.benzinga.com/apis/
# When set, replaces Yahoo Finance / SEC EDGAR as the source for:
#   • Earnings surprise % and beat streak  (scoring.js conviction signals)
#   • Symbol news headlines                (scoring.js guidance signal)
# Falls back to Yahoo/EDGAR automatically if this key is missing or Benzinga fails.
BENZINGA_API=bz....

# ── Email — OTP login (Resend) ────────────────────────────────────────────────
# Used to send one-time login codes to users. Get from: https://resend.com
RESEND_API=re_...
RESEND_FROM=alerts@yourdomain.com

# ── Email — Alerts (SMTP via Zoho / Google Workspace / any SMTP) ─────────────
# Used for EOD summary, trade fills, and research pipeline notifications.
# Zoho Mail:        SMTP_HOST=smtp.zoho.com        SMTP_PORT=465
# Google Workspace: SMTP_HOST=smtp.gmail.com        SMTP_PORT=465
# All alerts go to ALERT_EMAIL (defaults to SMTP_USER if not set).
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=info@trading.dlpinnovations.com
SMTP_PASS=your_email_password
ALERT_EMAIL=info@trading.dlpinnovations.com

# ── Pre-Close Sentinel ────────────────────────────────────────────────────────
# SMTP settings above are reused. Add only the sentinel-specific vars:
SENTINEL_EMAIL_FROM=info@trading.dlpinnovations.com
SENTINEL_EMAIL_TO=your@email.com
# Public URL of the dashboard (no trailing slash) — used to build one-click action links
PUBLIC_URL=https://your-dashboard.example.com
# 32+ char random secret for HMAC-signed action tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACTION_SIGNING_SECRET=change-this-to-a-long-random-secret
# Max % drift between proposal price and live price before execute is refused (default 0.02 = 2%)
SENTINEL_DRIFT_TOLERANCE=0.02

# ── Neo4j Graph Database ──────────────────────────────────────────────────────
# Community Edition (self-hosted): neo4j://localhost:7687
# AuraDB Free (cloud):             neo4j+s://xxxxxxxx.databases.neo4j.io
# Install locally (Mac): brew install neo4j && neo4j start
# Then open http://localhost:7474 and set a password.
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-password


# ── Unusual Whales API ────────────────────────────────────────────────────────
# Advanced plan: 120 req/min, 80,000 req/day, 90-day historical lookback
# WebSocket streaming for real-time options flow alerts
# Personal use only — do NOT expose raw UW data to public routes
# Get your key at: https://unusualwhales.com/api
UW_API_KEY=your_unusualwhales_api_key_here

# UW data retention windows (days). Rows older than these thresholds are pruned at 3 AM ET daily.
UW_FLOW_RETENTION_DAYS=90
UW_MOVERS_RETENTION_DAYS=30
UW_OPTIONS_FLOW_RETENTION_DAYS=90
